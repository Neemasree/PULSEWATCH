PORT=3000
REDIS_HOST=localhost
REDIS_PORT=6379
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALLOWED_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Connection string for Postgres. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev example (after running: createdb pulsewatch):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulsewatch
# Hosted (Railway, Supabase, Render) — copy the connection string from the dashboard.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulsewatch

# ── JWT secrets ───────────────────────────────────────────────────────────────
# REQUIRED in production — the app falls back to hardcoded dev secrets if these
# are not set, which is insecure. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use separate values — a compromised access secret must not compromise refresh tokens.
JWT_ACCESS_SECRET=change-this-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string-in-production
